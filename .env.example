# -- Общее --
PROJECT_NAME=
STACK_NAME=

# local | staging | production
ENVIRONMENT=local

# -- Домен и фронтенд --
# Локально: localhost
# Production: IP сервера или домен (например, 123.45.67.89)
DOMAIN=localhost

FRONTEND_HOST=

# -- CORS --
# Локально: все localhost-ы
# Production: http://<IP_СЕРВЕРА>
BACKEND_CORS_ORIGINS=

# -- Безопасность --
# Сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# -- PostgreSQL --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "db"
POSTGRES_SERVER=localhost
POSTGRES_PORT=
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# -- Redis --
# Без Docker: localhost
# С Docker: не важно, compose переопределяет на "redis://redis:6379/0"
REDIS_URL=

# -- Email (опционально) --
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=

# -- Мониторинг (опционально) --
SENTRY_DSN=

# -- AI Agent: LLM Providers --
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=qwen/qwen3.5-9b
OPENAI_BASE_URL=https://api.proxyapi.ru/openrouter/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# -- App LLM rate limiting --
CHAT_FREE_DAILY_LIMIT=20
CHAT_FREE_MAX_TOKENS=500


# -- Docker-образы --
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# =============================================================================
# Langfuse --- self-hosted LLM tracing
# =============================================================================

LANGFUSE_DB_USER=postgres
LANGFUSE_DB_PASSWORD=changeme
LANGFUSE_DB_NAME=postgres

LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=changeme

LANGFUSE_MINIO_USER=minio
LANGFUSE_MINIO_PASSWORD=changeme

NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=GENERATE_ME
SALT=GENERATE_ME
ENCRYPTION_KEY=GENERATE_ME

LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=changeme

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://langfuse-server:3000

TG_BOT_TOKEN=your-telegram-bot-token-here
TG_SUPERUSER_ID=your-telegram-user-id-here
TG_BOT_USERNAME=
TG_WEBHOOK_SECRET=

# -- CrowdSec (фаза 9: безопасность) --
# После первого запуска: cscli bouncers add my-bouncer внутри контейнера crowdsec
# Затем вставь сгенерированный ключ сюда и перезапусти bouncer
CROWDSEC_BOUNCER_KEY=changethis
