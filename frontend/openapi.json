    "/api/v1/dictionary/words": {
      "get": {
        "tags": ["dictionary"],
        "summary": "List Words",
        "description": "Search and filter dictionary words.\n\nQuery params:\n    q: Search text (matches word name and definitions).\n    pos: Part of speech filter (e.g. \"noun\", \"verb\", \"particle\").\n    word_set: Word set filter \u2014 \"pu\" for core words, \"ku\" for ku words.",
        "operationId": "dictionary-list_words",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "title": "Q"
            }
          },
          {
            "name": "pos",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "title": "Pos"
            }
          },
          {
            "name": "word_set",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "title": "Word Set"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "object", "additionalProperties": true },
                  "title": "Response Dictionary-List Words"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
